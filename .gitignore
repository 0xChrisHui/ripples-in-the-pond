# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code 本地设置（每台机器各自的权限授予记录，不入仓）
.claude/settings.local.json
# Claude Code 本地 worktree（隔离工作目录，不入仓）
.claude/worktrees/
# Claude Code 日志（触发 Tailwind v4 扫描 bug）
.claude/logs/

# Foundry 构建产物和敏感数据
contracts/out/
contracts/cache/
contracts/broadcast/

# Phase 3 S1：封面 SVG 是脚本确定性重建的（generate-covers.ts seed 化）
# 真正不可重建的是 cover-arweave-map.json（Arweave txid 永久记录），它要 commit
data/covers/
