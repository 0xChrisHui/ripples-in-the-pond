# Ripples in the Pond — 环境变量示例
# 用法：复制本文件为 .env.local，把每一项填上真实值
# 注意：.env.local 不会入 git（私钥/secret 千万别 commit）
# 前缀 NEXT_PUBLIC_ 的变量会暴露给浏览器，没前缀的只在后端能读到

# ─────────────────────────────────────────────────
# Privy（登录服务）
# 注册：https://dashboard.privy.io/  → Create new app → 复制 App ID 和 App Secret
# ─────────────────────────────────────────────────
# Privy App ID（前端登录用，可以暴露）
NEXT_PUBLIC_PRIVY_APP_ID=

# Privy App Secret（后端验证 JWT 用，绝不能暴露）
PRIVY_APP_SECRET=

# ─────────────────────────────────────────────────
# 链 & RPC（OP Sepolia 测试网 / OP Mainnet 生产）
# 项目主链是 Optimism (L2)，不是 Ethereum L1。详见 ARCHITECTURE.md 决策 3
# ─────────────────────────────────────────────────
# 链 ID：11155420 = OP Sepolia 测试网（生产时改为 10 = OP Mainnet）
NEXT_PUBLIC_CHAIN_ID=11155420

# Alchemy RPC（OP Sepolia）
# 注册：https://dashboard.alchemy.com/  → Create App → Network 选 "Optimism Sepolia" → 复制 HTTPS URL
# 前端用（只读，可以暴露 key）
NEXT_PUBLIC_ALCHEMY_RPC_URL=

# 后端用（同一个 URL 也可以；建议另开一个独立 key 方便审计）
ALCHEMY_RPC_URL=

# ─────────────────────────────────────────────────
# 运营钱包（OPERATOR）— 后端代付 gas 用
# 重要：用一个全新的测试钱包，永远别放主钱包私钥
# 去 https://app.optimism.io/faucet 给这个地址领 ≥ 0.02 OP-ETH
# 备用 faucet：https://www.alchemy.com/faucets/optimism-sepolia
# ─────────────────────────────────────────────────
# 私钥（0x 开头的 64 位十六进制），绝不能暴露，绝不能 commit
OPERATOR_PRIVATE_KEY=

# ─────────────────────────────────────────────────
# Supabase（数据库）
# 注册：https://supabase.com/dashboard  → New project → 复制 URL 和 keys
# Settings → API 里能看到下面三个值
# ─────────────────────────────────────────────────
# 项目 URL（前端也用，可以暴露）
NEXT_PUBLIC_SUPABASE_URL=

# anon key（前端用，权限受 RLS 限制）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service role key（后端用，绕过 RLS，绝不能暴露给前端）
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────
# Cron 触发密钥
# 自己随便起一个长字符串（建议 32 位以上随机字符），用于校验 cron 端点合法调用
# 生成示例：openssl rand -hex 32
# ─────────────────────────────────────────────────
CRON_SECRET=

# ─────────────────────────────────────────────────
# Admin 观测性 token（Phase 3 S5.c）
# GET /api/cron/queue-status?token=xxx 要带这个
# 用法：给 cron 操作者查 score_nft_queue 状态机卡住的任务
# 生成：openssl rand -hex 32（和 CRON_SECRET 格式一样，但值不同）
# ─────────────────────────────────────────────────
ADMIN_TOKEN=

# ─────────────────────────────────────────────────
# Arweave / Turbo（Phase 3 S0 — 底曲 / 音效 / decoder / metadata 永久存储）
# 付费方式：Turbo SDK + Base 链 ETH，用 topUpWithTokens() 链上交易换 credits
# 流程：
#   1. npx tsx scripts/arweave/generate-eth-wallet.ts  → 生成专用 ETH 钱包
#   2. MetaMask 在 Base 链转 ETH 到生成的地址
#   3. npx tsx scripts/arweave/wait-for-base-eth.ts    → 等到账
#   4. npx tsx scripts/arweave/topup-turbo.ts          → 换 credits
# ─────────────────────────────────────────────────
# 钱包 JSON 文件的绝对路径（含 privateKey + address + token 字段）
# 安全：文件路径必须在项目目录外。例：C:\Users\Hui\.ripples-secrets\turbo-wallet.json
TURBO_WALLET_PATH=

# Base 链 RPC URL（可选）。留空用公开 RPC https://mainnet.base.org
# 生产或频繁调用建议用 Alchemy/Infura 的 Base 端点避免限流
BASE_RPC_URL=

# ─────────────────────────────────────────────────
# Phase 3 S2 合约地址 — ScoreNFT (ERC-721)
# 部署方式：forge script contracts/script/DeployScore.s.sol
# 前缀 NEXT_PUBLIC_ 是因为前端未来需要展示合约地址和 OpenSea 链接
# ─────────────────────────────────────────────────
NEXT_PUBLIC_SCORE_NFT_ADDRESS=

# ─────────────────────────────────────────────────
# Phase 3 S3 合约地址 — MintOrchestrator
# ScoreNFT 的"前台"薄壳，S5 cron 走这个合约 mint
# 部署方式：SCORE_NFT_ADDRESS=0x... forge script DeployOrchestrator.s.sol
# ─────────────────────────────────────────────────
NEXT_PUBLIC_ORCHESTRATOR_ADDRESS=

# ─────────────────────────────────────────────────
# Phase 3 S4 — Score Decoder（"网页唱片机"）
# 自包含的 HTML 播放器，上传一次到 Arweave 后所有 ScoreNFT 共用
# 部署方式：npx tsx scripts/arweave/upload-decoder.ts
# 用途：S5 cron 生成 metadata 时把 animation_url 设成
#       https://arweave.net/<这里的 txid>?events=ar://...&base=ar://...&sounds=ar://...
# ─────────────────────────────────────────────────
SCORE_DECODER_AR_TX_ID=
