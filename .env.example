# 108 Cyber Records — 环境变量示例
# 用法：复制本文件为 .env.local，把每一项填上真实值
# 注意：.env.local 不会入 git（私钥/secret 千万别 commit）
# 前缀 NEXT_PUBLIC_ 的变量会暴露给浏览器，没前缀的只在后端能读到

# ─────────────────────────────────────────────────
# Privy（登录服务）
# 注册：https://dashboard.privy.io/  → Create new app → 复制 App ID 和 App Secret
# ─────────────────────────────────────────────────
# Privy App ID（前端登录用，可以暴露）
NEXT_PUBLIC_PRIVY_APP_ID=

# Privy App Secret（后端验证 JWT 用，绝不能暴露）
PRIVY_APP_SECRET=

# ─────────────────────────────────────────────────
# 链 & RPC（OP Sepolia 测试网 / OP Mainnet 生产）
# 项目主链是 Optimism (L2)，不是 Ethereum L1。详见 ARCHITECTURE.md 决策 3
# ─────────────────────────────────────────────────
# 链 ID：11155420 = OP Sepolia 测试网（生产时改为 10 = OP Mainnet）
NEXT_PUBLIC_CHAIN_ID=11155420

# Alchemy RPC（OP Sepolia）
# 注册：https://dashboard.alchemy.com/  → Create App → Network 选 "Optimism Sepolia" → 复制 HTTPS URL
# 前端用（只读，可以暴露 key）
NEXT_PUBLIC_ALCHEMY_RPC_URL=

# 后端用（同一个 URL 也可以；建议另开一个独立 key 方便审计）
ALCHEMY_RPC_URL=

# ─────────────────────────────────────────────────
# 运营钱包（OPERATOR）— 后端代付 gas 用
# 重要：用一个全新的测试钱包，永远别放主钱包私钥
# 去 https://app.optimism.io/faucet 给这个地址领 ≥ 0.02 OP-ETH
# 备用 faucet：https://www.alchemy.com/faucets/optimism-sepolia
# ─────────────────────────────────────────────────
# 私钥（0x 开头的 64 位十六进制），绝不能暴露，绝不能 commit
OPERATOR_PRIVATE_KEY=

# ─────────────────────────────────────────────────
# Supabase（数据库）
# 注册：https://supabase.com/dashboard  → New project → 复制 URL 和 keys
# Settings → API 里能看到下面三个值
# ─────────────────────────────────────────────────
# 项目 URL（前端也用，可以暴露）
NEXT_PUBLIC_SUPABASE_URL=

# anon key（前端用，权限受 RLS 限制）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service role key（后端用，绕过 RLS，绝不能暴露给前端）
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────
# Cron 触发密钥
# 自己随便起一个长字符串（建议 32 位以上随机字符），用于校验 cron 端点合法调用
# 生成示例：openssl rand -hex 32
# ─────────────────────────────────────────────────
CRON_SECRET=
